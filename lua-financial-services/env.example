# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to "true" to skip real OTP verification (demo OTP will always be 123456)
DEMO_MODE=true

# ─── Lua Platform ─────────────────────────────────────────────────────────────
# Set automatically by lua-cli during `lua init` — do not edit manually
# LUA_API_KEY=
# LUA_AGENT_ID=

# ─── WhatsApp Channel ─────────────────────────────────────────────────────────
# The WhatsApp Business channel ID from the Lua platform dashboard
# WHATSAPP_CHANNEL_ID=
